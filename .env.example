# ─── Database (Supabase PostgreSQL) ───
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ─── Supabase (Storage + Auth) ───
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── Authentication Secrets ───
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_generate_random_64_char_hex"
SESSION_SECRET="CHANGE_ME_generate_random_64_char_hex"

# ─── WebSocket / Device Secrets ───
DEVICE_SECRET_KEY="CHANGE_ME_generate_random_64_char_hex"
DEVICE_JWT_SECRET="CHANGE_ME_generate_random_64_char_hex"

# ─── Redis (required for realtime + token revocation) ───
REDIS_URL="redis://localhost:6379"

# ─── CORS ───
# REQUIRED in production. Comma-separated list of allowed frontend origins
# (no trailing slash). Without this set, the API refuses to boot in
# production — we used to fall back to a .vercel.app wildcard which let
# any Vercel-hosted page make authenticated cross-origin requests.
ALLOWED_ORIGINS="https://your-app.vercel.app"

# ─── API Server ───
PORT=8080
NODE_ENV=development

# ─── Onboarding emails ───
# Base URL used when generating password-reset and invite links in outbound
# emails. Should match the deployed web origin (e.g. https://edusignage.example).
APP_PUBLIC_URL="http://localhost:3000"

# ─── Web → API base URL (REQUIRED in production) ────────────────────────────
# The browser bundle uses this to call the NestJS API. Without it, the
# deployed site falls back to http://localhost:8080 and every request fails
# with "Cannot connect to the server. Make sure the API is running."
#
# Local dev:   NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
# Production:  NEXT_PUBLIC_API_URL=https://<your-railway-app>.up.railway.app/api/v1
#
# On Vercel: Settings → Environment Variables → add NEXT_PUBLIC_API_URL for
# Production/Preview/Development, paste the Railway public domain + /api/v1,
# then redeploy. Remember the trailing /api/v1 — the backend mounts all
# routes under that prefix.
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# ─── CSRF enforcement ───
# ENFORCE is now the default. The middleware blocks mutations with invalid
# or missing X-CSRF-Token headers unless you explicitly opt out:
#   CSRF_ENFORCE=false  → warn-only (logs, does not block)
#   CSRF_WARN=true      → warn-only (alias)
# Leave both unset in production.
# CSRF_ENFORCE=
# CSRF_WARN=

# ─── Dev-only WebSocket bypass ───
# When NODE_ENV!=production AND DEV_WS_ALLOW=true, the realtime gateway
# accepts unsigned `dev_<deviceId>_<tenantId>` tokens without JWT
# verification. NEVER set this in production — it bypasses all device
# auth on the signed-message channel.
# DEV_WS_ALLOW=

# ─── GrowthBook self-hosted feature flags ────────────────────────────────────
# Run `docker compose up growthbook` then open http://localhost:3100 to create
# an SDK Connection; paste the generated key below.
# Leave blank to fall back to the FF_* env-var switches below.
GROWTHBOOK_API_HOST=http://localhost:3100
GROWTHBOOK_CLIENT_KEY=                    # e.g. sdk-abc123

# Web-side GrowthBook (browser bundle). Must match the Server-Side SDK key
# for the same environment in GrowthBook, or a separate Browser SDK key.
NEXT_PUBLIC_GROWTHBOOK_API_HOST=http://localhost:3100
NEXT_PUBLIC_GROWTHBOOK_CLIENT_KEY=        # e.g. sdk-abc123

# ─── Feature flag env-var fallback ───────────────────────────────────────────
# Used when GrowthBook is unreachable or keys are missing.
# API-side — server reads these. Only exact value "true" enables a flag.
FF_EMERGENCY_NEW_UI=false
FF_TEMPLATE_BUILDER_V2=false
FF_SIS_INTEGRATION=false
# Web-side — exposed to the browser bundle (requires rebuild to change).
NEXT_PUBLIC_FF_EMERGENCY_NEW_UI=false
NEXT_PUBLIC_FF_TEMPLATE_BUILDER_V2=false
NEXT_PUBLIC_FF_SIS_INTEGRATION=false

# ─── SSO (SAML + OIDC) ──────────────────────────────────────────────────────
# At-rest encryption key for tenant SSO secrets (x509 certs, OIDC client
# secrets). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Without this the API falls back to a dev-only key and refuses to trust
# stored secrets across deploys — always set explicitly in production.
SSO_ENCRYPTION_KEY=

# Public base URL for the API (used to build SP metadata URLs for IdP setup).
# Optional — falls back to the incoming request's host/proto headers.
PUBLIC_API_BASE_URL=

# Public URL for the web app (used to redirect back after SSO callback).
WEB_PUBLIC_URL=http://localhost:3000

# ─── Sentry error tracking (free tier: https://sentry.io) ───
# Leave empty in dev if you don't have a DSN — app will run without it.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
GIT_COMMIT_SHA=

# ─── Clever SIS integration (Sprint 3) ───
# OAuth app credentials from https://dev.clever.com/ — obtain via sandbox account.
CLEVER_CLIENT_ID=
CLEVER_CLIENT_SECRET=
# Where Clever redirects after the OAuth consent screen. Must match the app config
# in the Clever developer dashboard. If unset, derived from request headers in dev.
CLEVER_REDIRECT_URI=
# Where the user is sent after a successful connect (relative URL on the web app).
CLEVER_POST_CONNECT_URL=/
# 64-char hex (32 bytes) — used for AES-256-GCM encryption of stored access tokens.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CLEVER_ENCRYPTION_KEY=
# Set to "1" to disable the nightly 02:00 roster sync cron (dev convenience).
CLEVER_CRON_DISABLED=
