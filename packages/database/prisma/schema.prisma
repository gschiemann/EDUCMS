generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id                      String        @id @default(uuid())
  parentId                String?       @map("parent_id")
  name                    String
  slug                    String        @unique
  emergencyStatus         String        @default("INACTIVE") @map("emergency_status")
  createdAt               DateTime      @default(now()) @map("created_at")
  emergencyPlaylistId     String?       @map("emergency_playlist_id")
  panicEvacuatePlaylistId String?       @map("panic_evacuate_playlist_id")
  panicLockdownPlaylistId String?       @map("panic_lockdown_playlist_id")
  panicWeatherPlaylistId  String?       @map("panic_weather_playlist_id")
  assetFolders            AssetFolder[]
  assets                  Asset[]
  auditLogs               AuditLog[]
  playlists               Playlist[]
  schedules               Schedule[]
  screenGroups            ScreenGroup[]
  screens                 Screen[]
  templates               Template[]
  parent                  Tenant?       @relation("TenantHierarchy", fields: [parentId], references: [id])
  children                Tenant[]      @relation("TenantHierarchy")
  users                   User[]
  ssoConfig               TenantSSOConfig?
  cleverDistrictId        String?       @unique @map("clever_district_id")
  cleverAccessToken       String?       @map("clever_access_token")
  cleverConnectedAt       DateTime?     @map("clever_connected_at")
  cleverSyncLogs          CleverSyncLog[]

  @@map("tenants")
}

model TenantSSOConfig {
  id                String   @id @default(uuid())
  tenantId          String   @unique @map("tenant_id")
  provider          String   // 'SAML' | 'OIDC'
  enabled           Boolean  @default(false)
  metadataUrl       String?  @map("metadata_url")
  entityId          String?  @map("entity_id")
  acsUrl            String?  @map("acs_url")
  x509Cert          String?  @map("x509_cert")           // encrypted at rest
  oidcIssuer        String?  @map("oidc_issuer")
  oidcClientId      String?  @map("oidc_client_id")
  oidcClientSecret  String?  @map("oidc_client_secret")  // encrypted at rest
  defaultRole       String   @default("RESTRICTED_VIEWER") @map("default_role")
  allowedEmailDomain String? @map("allowed_email_domain")
  autoProvision     Boolean  @default(false) @map("auto_provision")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_sso_configs")
}

model User {
  id               String     @id @default(uuid())
  tenantId         String     @map("tenant_id")
  email            String     @unique
  passwordHash     String     @map("password_hash")
  role             String
  canTriggerPanic  Boolean    @default(false) @map("can_trigger_panic")
  createdAt        DateTime   @default(now()) @map("created_at")
  assets           Asset[]
  auditLogs        AuditLog[]
  createdTemplates Template[] @relation("TemplateCreator")
  tenant           Tenant     @relation(fields: [tenantId], references: [id])
  cleverId         String?    @unique @map("clever_id")
  cleverRole       String?    @map("clever_role")

  @@map("users")
}

model CleverSyncLog {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  syncStartedAt     DateTime  @default(now()) @map("sync_started_at")
  syncCompletedAt   DateTime? @map("sync_completed_at")
  usersAdded        Int       @default(0) @map("users_added")
  usersUpdated      Int       @default(0) @map("users_updated")
  usersDisabled     Int       @default(0) @map("users_disabled")
  errorMessage      String?   @map("error_message")
  tenant            Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId, syncStartedAt])
  @@map("clever_sync_logs")
}

model ScreenGroup {
  id          String     @id @default(uuid())
  tenantId    String     @map("tenant_id")
  name        String
  description String?
  createdAt   DateTime   @default(now()) @map("created_at")
  schedules   Schedule[]
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  screens     Screen[]

  @@map("screen_groups")
}

model Screen {
  id                String       @id @default(uuid())
  tenantId          String?      @map("tenant_id")
  screenGroupId     String?      @map("screen_group_id")
  name              String
  location          String?
  deviceFingerprint String       @unique @map("device_fingerprint")
  pairingCode       String?      @unique @map("pairing_code")
  status            String       @default("PENDING")
  lastPingAt        DateTime?    @map("last_ping_at")
  pairedAt          DateTime?    @map("paired_at")
  resolution        String?
  osInfo            String?      @map("os_info")
  browserInfo       String?      @map("browser_info")
  ipAddress         String?      @map("ip_address")
  userAgent         String?      @map("user_agent")
  schedules         Schedule[]
  screenGroup       ScreenGroup? @relation(fields: [screenGroupId], references: [id])
  tenant            Tenant?      @relation(fields: [tenantId], references: [id])

  @@map("screens")
}

model AssetFolder {
  id        String        @id @default(uuid())
  tenantId  String        @map("tenant_id")
  parentId  String?       @map("parent_id")
  name      String
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @default(now()) @updatedAt @map("updated_at")
  tenant    Tenant        @relation(fields: [tenantId], references: [id])
  parent    AssetFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id])
  children  AssetFolder[] @relation("FolderHierarchy")
  assets    Asset[]

  @@map("asset_folders")
}

model Asset {
  id               String         @id @default(uuid())
  tenantId         String         @map("tenant_id")
  uploadedByUserId String         @map("uploaded_by_user_id")
  folderId         String?        @map("folder_id")
  fileUrl          String         @map("file_url")
  mimeType         String         @map("mime_type")
  status           String         @default("PENDING_APPROVAL")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @default(now()) @updatedAt @map("updated_at")
  fileSize         Int?           @map("file_size")
  originalName     String?        @map("original_name")
  uploadedBy       User           @relation(fields: [uploadedByUserId], references: [id])
  tenant           Tenant         @relation(fields: [tenantId], references: [id])
  folder           AssetFolder?   @relation(fields: [folderId], references: [id])
  playlistItems    PlaylistItem[]

  @@map("assets")
}

model Playlist {
  id         String         @id @default(uuid())
  tenantId   String         @map("tenant_id")
  name       String
  templateId String?        @map("template_id")
  items      PlaylistItem[]
  tenant     Tenant         @relation(fields: [tenantId], references: [id])
  template   Template?      @relation(fields: [templateId], references: [id])
  schedules  Schedule[]

  @@map("playlists")
}

model PlaylistItem {
  id            String   @id @default(uuid())
  playlistId    String   @map("playlist_id")
  assetId       String   @map("asset_id")
  durationMs    Int      @map("duration_ms")
  sequenceOrder Int      @map("sequence_order")
  daysOfWeek    String?  @map("days_of_week")
  timeStart     String?  @map("time_start")
  timeEnd       String?  @map("time_end")
  transitionType String? @default("FADE") @map("transition_type")
  asset         Asset    @relation(fields: [assetId], references: [id])
  playlist      Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@map("playlist_items")
}

model Schedule {
  id            String       @id @default(uuid())
  tenantId      String       @map("tenant_id")
  playlistId    String       @map("playlist_id")
  screenGroupId String?      @map("screen_group_id")
  screenId      String?      @map("screen_id")
  startTime     DateTime     @map("start_time")
  endTime       DateTime?    @map("end_time")
  daysOfWeek    String?      @map("days_of_week")
  timeStart     String?      @map("time_start")
  timeEnd       String?      @map("time_end")
  priority      Int          @default(0)
  isActive      Boolean      @default(true) @map("is_active")
  screen        Screen?      @relation(fields: [screenId], references: [id])
  screenGroup   ScreenGroup? @relation(fields: [screenGroupId], references: [id])
  playlist      Playlist     @relation(fields: [playlistId], references: [id])
  tenant        Tenant       @relation(fields: [tenantId], references: [id])

  @@map("schedules")
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  userId     String?  @map("user_id")
  action     String
  targetType String   @map("target_type")
  targetId   String?  @map("target_id")
  details    String?
  createdAt  DateTime @default(now()) @map("created_at")
  user       User?    @relation(fields: [userId], references: [id])
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@map("audit_logs")
}

model Template {
  id           String         @id @default(uuid())
  tenantId     String?        @map("tenant_id")
  name         String
  description  String?
  category     String         @default("CUSTOM")
  orientation  String         @default("LANDSCAPE")
  screenWidth  Int            @default(1920) @map("screen_width")
  screenHeight Int            @default(1080) @map("screen_height")
  isSystem     Boolean        @default(false) @map("is_system")
  status       String         @default("ACTIVE")
  bgColor      String?        @map("bg_color")
  bgImage      String?        @map("bg_image")
  bgGradient   String?        @map("bg_gradient")
  thumbnail    String?
  createdById  String?        @map("created_by_id")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @default(now()) @updatedAt @map("updated_at")
  zones        TemplateZone[]
  playlists    Playlist[]
  createdBy    User?          @relation("TemplateCreator", fields: [createdById], references: [id])
  tenant       Tenant?        @relation(fields: [tenantId], references: [id])

  @@map("templates")
}

model TemplateZone {
  id            String   @id @default(uuid())
  templateId    String   @map("template_id")
  name          String
  widgetType    String   @map("widget_type")
  x             Float    @default(0)
  y             Float    @default(0)
  width         Float    @default(100)
  height        Float    @default(100)
  zIndex        Int      @default(0) @map("z_index")
  sortOrder     Int      @default(0) @map("sort_order")
  defaultConfig String?  @map("default_config")
  template      Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("template_zones")
}
