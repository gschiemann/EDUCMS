generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id                      String        @id @default(uuid())
  parentId                String?       @map("parent_id")
  name                    String
  slug                    String        @unique
  emergencyStatus         String        @default("INACTIVE") @map("emergency_status")
  createdAt               DateTime      @default(now()) @map("created_at")
  emergencyPlaylistId     String?       @map("emergency_playlist_id")
  panicEvacuatePlaylistId String?       @map("panic_evacuate_playlist_id")
  panicLockdownPlaylistId String?       @map("panic_lockdown_playlist_id")
  panicWeatherPlaylistId  String?       @map("panic_weather_playlist_id")
  // SRP (Standard Response Protocol) expansion — most US K-12 districts
  // train on these specific actions. Hold + Secure + Medical added so
  // operators don't have to over-trigger Lockdown for hallway clearing
  // (Hold), outside-only threats (Secure), or medical events (Medical).
  panicHoldPlaylistId     String?       @map("panic_hold_playlist_id")
  panicSecurePlaylistId   String?       @map("panic_secure_playlist_id")
  panicMedicalPlaylistId  String?       @map("panic_medical_playlist_id")
  assetFolders            AssetFolder[]
  assets                  Asset[]
  auditLogs               AuditLog[]
  playlists               Playlist[]
  schedules               Schedule[]
  screenGroups            ScreenGroup[]
  screens                 Screen[]
  templates               Template[]
  notifications           Notification[]
  parent                  Tenant?       @relation("TenantHierarchy", fields: [parentId], references: [id])
  children                Tenant[]      @relation("TenantHierarchy")
  users                   User[]
  ssoConfig               TenantSSOConfig?
  cleverDistrictId        String?       @unique @map("clever_district_id")
  cleverAccessToken       String?       @map("clever_access_token")
  cleverConnectedAt       DateTime?     @map("clever_connected_at")
  cleverSyncLogs          CleverSyncLog[]
  userInvites             UserInvite[]
  // USB sneakernet ingest (Sprint 7B). Off by default; admins opt in per
  // tenant. The HMAC key signs every USB bundle's manifest.json so a
  // random/stolen stick can't push content to a paired screen. Rotated
  // by an admin via POST /tenants/me/usb-ingest-key/rotate.
  usbIngestEnabled        Boolean       @default(false) @map("usb_ingest_enabled")
  usbIngestKey            String?       @map("usb_ingest_key")             // 64-char hex (HMAC-SHA256 secret)
  usbIngestKeyRotatedAt   DateTime?     @map("usb_ingest_key_rotated_at")
  usbIngestEvents         UsbIngestEvent[]
  // Industry vertical — drives default templates, widget palette, and
  // pricing tier. Tenants are isolated regardless; this is just metadata
  // + UI personalization.
  vertical                String        @default("K12") // K12 | RESTAURANT | RETAIL | HEALTHCARE | CORPORATE | OTHER
  // Per-screen billing meter. One License row per Tenant; absence means
  // "Pilot" (free tier with cap of 3 screens, no expiry). License flips
  // when an admin runs a Stripe checkout or the SUPER_ADMIN comps seats.
  license                 License?

  @@map("tenants")
}

model TenantSSOConfig {
  id                String   @id @default(uuid())
  tenantId          String   @unique @map("tenant_id")
  provider          String   // 'SAML' | 'OIDC'
  enabled           Boolean  @default(false)
  metadataUrl       String?  @map("metadata_url")
  entityId          String?  @map("entity_id")
  acsUrl            String?  @map("acs_url")
  x509Cert          String?  @map("x509_cert")           // encrypted at rest
  oidcIssuer        String?  @map("oidc_issuer")
  oidcClientId      String?  @map("oidc_client_id")
  oidcClientSecret  String?  @map("oidc_client_secret")  // encrypted at rest
  defaultRole       String   @default("RESTRICTED_VIEWER") @map("default_role")
  allowedEmailDomain String? @map("allowed_email_domain")
  autoProvision     Boolean  @default(false) @map("auto_provision")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_sso_configs")
}

model User {
  id               String               @id @default(uuid())
  tenantId         String               @map("tenant_id")
  email            String               @unique
  passwordHash     String               @map("password_hash")
  role             String
  canTriggerPanic  Boolean              @default(false) @map("can_trigger_panic")
  status           String               @default("ACTIVE")
  createdAt        DateTime             @default(now()) @map("created_at")
  assets           Asset[]
  auditLogs        AuditLog[]
  createdTemplates Template[]           @relation("TemplateCreator")
  tenant           Tenant               @relation(fields: [tenantId], references: [id])
  cleverId         String?              @unique @map("clever_id")
  cleverRole       String?              @map("clever_role")
  passwordResets   PasswordResetToken[]
  invitesSent      UserInvite[]         @relation("InviteInviter")
  invite           UserInvite?          @relation("InviteUser")
  notifications    Notification[]

  @@map("users")
}

model CleverSyncLog {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  syncStartedAt     DateTime  @default(now()) @map("sync_started_at")
  syncCompletedAt   DateTime? @map("sync_completed_at")
  usersAdded        Int       @default(0) @map("users_added")
  usersUpdated      Int       @default(0) @map("users_updated")
  usersDisabled     Int       @default(0) @map("users_disabled")
  errorMessage      String?   @map("error_message")
  tenant            Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId, syncStartedAt])
  @@map("clever_sync_logs")
}

model PasswordResetToken {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  tokenHash  String   @unique @map("token_hash")
  expiresAt  DateTime @map("expires_at")
  usedAt     DateTime? @map("used_at")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model UserInvite {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  email       String
  role        String
  tokenHash   String    @unique @map("token_hash")
  invitedById String    @map("invited_by_id")
  userId      String?   @unique @map("user_id")
  expiresAt   DateTime  @map("expires_at")
  acceptedAt  DateTime? @map("accepted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  invitedBy   User      @relation("InviteInviter", fields: [invitedById], references: [id])
  user        User?     @relation("InviteUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([email])
  @@map("user_invites")
}

// Per-tenant license. The billing meter is the count of paired Screens
// (Screen.tenantId IS NOT NULL AND Screen.pairedAt IS NOT NULL). When
// register() would push currentSeats above seatLimit, we reject with a
// LICENSE_EXHAUSTED error and instruct the admin to add seats.
model License {
  id            String    @id @default(uuid())
  tenantId      String    @unique @map("tenant_id")
  tier          String    // PILOT | STANDARD | ENTERPRISE | EDU_DISTRICT | RESTAURANT_CHAIN | (custom)
  seatLimit     Int       @default(3) @map("seat_limit")
  billingMode   String    @default("CARD") @map("billing_mode") // CARD | INVOICE | PURCHASE_ORDER | COMP
  status        String    @default("ACTIVE")              // ACTIVE | PAST_DUE | SUSPENDED | CANCELLED
  monthlyPriceCents Int?  @map("monthly_price_cents")    // null for COMP / EDU_DISTRICT custom
  // Stripe wire-up slots — populated when the customer runs in-app
  // checkout. Empty for COMP, INVOICE, PURCHASE_ORDER customers.
  stripeCustomerId      String?   @map("stripe_customer_id")
  stripeSubscriptionId  String?   @map("stripe_subscription_id")
  // Expiry / renewal. Null = perpetual (e.g. PILOT, COMP).
  currentPeriodStart    DateTime? @map("current_period_start")
  currentPeriodEnd      DateTime? @map("current_period_end")
  expiresAt             DateTime? @map("expires_at")
  // Free-form notes from the SUPER_ADMIN (e.g. "manually comp'd 5 seats
  // through 2026-09-01 — ARRA grant").
  notes                 String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at")
  tenant                Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("licenses")
}

model UsbIngestEvent {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  screenId        String?  @map("screen_id")
  deviceSerial    String?  @map("device_serial") // USB stick volume serial
  bundleVersion   String?  @map("bundle_version") // version field from manifest.json
  assetCount      Int      @default(0) @map("asset_count")
  totalBytes      BigInt   @default(0) @map("total_bytes")
  emergencyAssets Boolean  @default(false) @map("emergency_assets") // true if bundle contained any emergency assets
  outcome         String   // 'ACCEPTED' | 'REJECTED_SIGNATURE' | 'REJECTED_HASH' | 'CANCELLED_BY_OPERATOR' | 'PARTIAL'
  reason          String?
  operatorPin     String?  @map("operator_pin") // SHA-256 of pin used; never store the raw pin
  createdAt       DateTime @default(now()) @map("created_at")
  // MED-2 audit fix: cascade delete with the parent Tenant. RESTRICT
  // previously made any tenant that ever ingested a USB bundle
  // permanently undeletable.
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@map("usb_ingest_events")
}

model EmailLog {
  id        String   @id @default(uuid())
  toEmail   String   @map("to_email")
  subject   String
  body      String
  kind      String
  status    String   @default("QUEUED")
  error     String?
  createdAt DateTime @default(now()) @map("created_at")
  sentAt    DateTime? @map("sent_at")

  @@index([status])
  @@index([toEmail])
  @@map("email_logs")
}

model ScreenGroup {
  id          String     @id @default(uuid())
  tenantId    String     @map("tenant_id")
  name        String
  description String?
  createdAt   DateTime   @default(now()) @map("created_at")
  schedules   Schedule[]
  tenant      Tenant     @relation(fields: [tenantId], references: [id])
  screens     Screen[]

  @@map("screen_groups")
}

model Screen {
  id                String       @id @default(uuid())
  tenantId          String?      @map("tenant_id")
  screenGroupId     String?      @map("screen_group_id")
  name              String
  location          String?
  deviceFingerprint String       @unique @map("device_fingerprint")
  pairingCode       String?      @unique @map("pairing_code")
  status            String       @default("PENDING")
  lastPingAt        DateTime?    @map("last_ping_at")
  pairedAt          DateTime?    @map("paired_at")
  resolution        String?
  osInfo            String?      @map("os_info")
  browserInfo       String?      @map("browser_info")
  ipAddress         String?      @map("ip_address")
  userAgent         String?      @map("user_agent")
  // Sprint 8 — fleet map view. Optional geo + visual identification so
  // a 100-screen district can manage the fleet on a map instead of a
  // flat list. Address geocoded via Nominatim on save.
  address           String?
  latitude          Float?
  longitude         Float?
  photoUrl          String?      @map("photo_url")
  // Last offline-cache status the player reported. JSON shape:
  //   { playlist: { count, bytes }, emergency: { count, bytes } }
  // Lets admins verify each screen actually has emergency assets on disk
  // without trusting the network at the moment of an emergency.
  lastCacheReport   Json?        @map("last_cache_report")
  lastCacheReportAt DateTime?    @map("last_cache_report_at")
  schedules         Schedule[]
  screenGroup       ScreenGroup? @relation(fields: [screenGroupId], references: [id])
  tenant            Tenant?      @relation(fields: [tenantId], references: [id])

  @@map("screens")
}

model AssetFolder {
  id        String        @id @default(uuid())
  tenantId  String        @map("tenant_id")
  parentId  String?       @map("parent_id")
  name      String
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @default(now()) @updatedAt @map("updated_at")
  tenant    Tenant        @relation(fields: [tenantId], references: [id])
  parent    AssetFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id])
  children  AssetFolder[] @relation("FolderHierarchy")
  assets    Asset[]

  @@map("asset_folders")
}

model Asset {
  id               String         @id @default(uuid())
  tenantId         String         @map("tenant_id")
  uploadedByUserId String         @map("uploaded_by_user_id")
  folderId         String?        @map("folder_id")
  fileUrl          String         @map("file_url")
  mimeType         String         @map("mime_type")
  status           String         @default("PENDING_APPROVAL")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @default(now()) @updatedAt @map("updated_at")
  fileSize         Int?           @map("file_size")
  originalName     String?        @map("original_name")
  fileHash         String?        @map("file_hash") // SHA-256 hex, computed at upload time for offline-cache integrity
  uploadedBy       User           @relation(fields: [uploadedByUserId], references: [id])
  tenant           Tenant         @relation(fields: [tenantId], references: [id])
  folder           AssetFolder?   @relation(fields: [folderId], references: [id])
  playlistItems    PlaylistItem[]

  @@map("assets")
}

model Playlist {
  id         String         @id @default(uuid())
  tenantId   String         @map("tenant_id")
  name       String
  templateId String?        @map("template_id")
  // Protected playlists are owned by the system (e.g. emergency content
  // bound to Tenant.panicLockdownPlaylistId). They are hidden from the
  // /playlists list and cannot be deleted by an admin — preventing the
  // "I accidentally deleted the lockdown playlist mid-emergency" failure
  // mode. Created automatically by the panic-content endpoints and
  // managed only through that surface.
  isProtected Boolean       @default(false) @map("is_protected")
  protectedKind String?     @map("protected_kind") // 'lockdown' | 'weather' | 'evacuate' | null
  items      PlaylistItem[]
  tenant     Tenant         @relation(fields: [tenantId], references: [id])
  template   Template?      @relation(fields: [templateId], references: [id])
  schedules  Schedule[]

  @@index([tenantId, isProtected])
  @@map("playlists")
}

model PlaylistItem {
  id            String   @id @default(uuid())
  playlistId    String   @map("playlist_id")
  assetId       String   @map("asset_id")
  durationMs    Int      @map("duration_ms")
  sequenceOrder Int      @map("sequence_order")
  daysOfWeek    String?  @map("days_of_week")
  timeStart     String?  @map("time_start")
  timeEnd       String?  @map("time_end")
  transitionType String? @default("FADE") @map("transition_type")
  asset         Asset    @relation(fields: [assetId], references: [id])
  playlist      Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  @@map("playlist_items")
}

model Schedule {
  id            String       @id @default(uuid())
  tenantId      String       @map("tenant_id")
  playlistId    String       @map("playlist_id")
  screenGroupId String?      @map("screen_group_id")
  screenId      String?      @map("screen_id")
  startTime     DateTime     @map("start_time")
  endTime       DateTime?    @map("end_time")
  daysOfWeek    String?      @map("days_of_week")
  timeStart     String?      @map("time_start")
  timeEnd       String?      @map("time_end")
  priority      Int          @default(0)
  isActive      Boolean      @default(true) @map("is_active")
  screen        Screen?      @relation(fields: [screenId], references: [id])
  screenGroup   ScreenGroup? @relation(fields: [screenGroupId], references: [id])
  playlist      Playlist     @relation(fields: [playlistId], references: [id])
  tenant        Tenant       @relation(fields: [tenantId], references: [id])

  @@map("schedules")
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  userId     String?  @map("user_id")
  action     String
  targetType String   @map("target_type")
  targetId   String?  @map("target_id")
  details    String?
  createdAt  DateTime @default(now()) @map("created_at")
  user       User?    @relation(fields: [userId], references: [id])
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String?  @map("user_id")
  kind      String
  title     String
  body      String?
  link      String?
  isRead    Boolean  @default(false) @map("is_read")
  dedupeKey String?  @map("dedupe_key")
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])

  @@index([tenantId, userId, isRead])
  @@index([tenantId, createdAt])
  @@unique([tenantId, dedupeKey])
  @@map("notifications")
}

model Template {
  id           String         @id @default(uuid())
  tenantId     String?        @map("tenant_id")
  name         String
  description  String?
  category     String         @default("CUSTOM")
  orientation  String         @default("LANDSCAPE")
  // Filter chip on /templates — 'ELEMENTARY' | 'MIDDLE' | 'HIGH' | 'UNIVERSAL'.
  // Stored as a free string so we don't need a DB enum migration each time
  // a new level (PRE_K, ADULT_ED, etc.) comes along. Defaults to UNIVERSAL
  // so existing templates stay visible under every filter.
  schoolLevel  String         @default("UNIVERSAL") @map("school_level")
  screenWidth  Int            @default(1920) @map("screen_width")
  screenHeight Int            @default(1080) @map("screen_height")
  isSystem     Boolean        @default(false) @map("is_system")
  status       String         @default("ACTIVE")
  bgColor      String?        @map("bg_color")
  bgImage      String?        @map("bg_image")
  bgGradient   String?        @map("bg_gradient")
  thumbnail    String?
  createdById  String?        @map("created_by_id")
  isTouchEnabled Boolean      @default(false) @map("is_touch_enabled")
  idleResetMs  Int            @default(60000) @map("idle_reset_ms")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @default(now()) @updatedAt @map("updated_at")
  zones        TemplateZone[]
  playlists    Playlist[]
  createdBy    User?          @relation("TemplateCreator", fields: [createdById], references: [id])
  tenant       Tenant?        @relation(fields: [tenantId], references: [id])

  @@map("templates")
}

model EmergencyMessage {
  id                 String    @id @default(uuid())
  tenantId           String    @map("tenant_id")
  triggeredByUserId  String?   @map("triggered_by_user_id")
  type               String
  severity           String    @default("CRITICAL")
  textBlob           String?   @map("text_blob")
  mediaUrls          String?   @map("media_urls")
  audioUrl           String?   @map("audio_url")
  scopeType          String    @map("scope_type")
  scopeId            String    @map("scope_id")
  expiresAt          DateTime? @map("expires_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  clearedAt          DateTime? @map("cleared_at")
  clearedByUserId    String?   @map("cleared_by_user_id")

  @@index([tenantId, createdAt(sort: Desc)], map: "emergency_messages_tenant_created_idx")
  @@map("emergency_messages")
}

model TemplateZone {
  id            String   @id @default(uuid())
  templateId    String   @map("template_id")
  name          String
  widgetType    String   @map("widget_type")
  x             Float    @default(0)
  y             Float    @default(0)
  width         Float    @default(100)
  height        Float    @default(100)
  zIndex        Int      @default(0) @map("z_index")
  sortOrder     Int      @default(0) @map("sort_order")
  defaultConfig String?  @map("default_config")
  touchAction   Json?    @map("touch_action")
  template      Template @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("template_zones")
}
