    "isomorphic-dompurify": "^3.8.0",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "multer": "^1.4.5-lts.1",
    "openid-client": "^5.7.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-saml": "^3.2.4",
    "postcss": "^8.5.10",
    "postcss-value-parser": "^4.2.0",
    "puppeteer-core": "^22.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sanitize-html": "^2.17.2",
    "uuid": "^13.0.0",
