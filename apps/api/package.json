    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-ws": "^11.1.19",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.19",
    "@openfeature/core": "^1.9.2",
    "@openfeature/server-sdk": "^1.20.2",
    "@sentry/nestjs": "^10.49.0",
    "@sentry/node": "^10.49.0",
