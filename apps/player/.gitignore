.gradle/
build/
local.properties
*.iml
.idea/
.kotlin/
captures/
*.apk
*.aab
# Bundled Manager APK is generated at build time by the
# bundleManagerApk Gradle task; never commit it.
app/src/main/assets/bundled/
*.keystore
*.jks
# Stable debug keystore (committed intentionally — see comment in
# build.gradle.kts). Debug keystores are not security-sensitive;
# Android shows a "this is a debug build" warning regardless. The
# benefit: every CI build signs with the same key, so OTA installs
# succeed across versions instead of being rejected with
# INSTALL_FAILED_UPDATE_INCOMPATIBLE.
!app/debug.keystore
release/
