<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Android 14+ requires a typed FGS permission. dataSync covers the
         heartbeat ping payload; if we ever add live audio/video capture
         we'd need 'mediaProjection' or similar. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- OTA self-install. Without this the install intent silently no-ops
         on Android 8+. Tenant must accept the install prompt OR set us
         as the default installer via `pm set-installer com.educms.player`
         (one-shot ADB), which makes installs silent.  -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <!-- USB OTG sneakernet ingest (Sprint 7B) — Android 7+ supports USB host mode -->
    <uses-feature android:name="android.hardware.usb.host" android:required="false" />
    <uses-feature android:name="android.hardware.touchscreen" android:required="false" />
    <uses-feature android:name="android.software.leanback" android:required="false" />

    <application
        android:name=".PlayerApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.EduCmsPlayer"
        android:usesCleartextTraffic="false"
        tools:targetApi="34">

        <!-- MainActivity is THE ONLY entry point. The WebView loads
             /player which handles the whole register → show pairing
             code → poll → play flow inside the web app. The APK is a
             kiosk shell; there is NO native pairing screen.
             PairingActivity was removed entirely (commit addressing
             operator-report 2026-04-20: some TV auto-launchers cached
             it as the default activity across app updates and showed
             the old "type your code" keyboard prompt on boot instead
             of the WebView). -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:screenOrientation="fullSensor"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|uiMode|smallestScreenSize"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:resizeableActivity="false"
            tools:ignore="LockedOrientationActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.educms.player.OPEN_PLAYER" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <!-- DELIBERATELY NO HOME category. We learned the hard way
                 2026-04-21 that registering `category.HOME` makes Android
                 treat us as a candidate launcher replacement. On OEM
                 signage boxes (Goodview, NovaStar, TCL) that already ship
                 a proprietary CMS/launcher, Android promptly asks the
                 user to pick a default — and if our app ever wins that
                 vote (or if we're the only launcher registered), we
                 DISPLACE the OEM launcher entirely. Goodview's own CMS
                 stops being reachable, their network-settings flow
                 breaks, and the screen drops off their dashboard. We
                 are a guest on the device, NOT the host. The OEM's CMS
                 is the launcher; we are an app they start. Leave this
                 comment in place; do NOT re-add HOME. If a customer
                 explicitly wants us as the kiosk launcher (no OEM CMS
                 underneath), ship a separate build flavor with the
                 HOME filter gated behind a `isKioskOnly` gradle flag.
              -->
            <!-- Backstop intent alias for the old com.educms.player.LEGACY_PAIR
                 action. TV auto-launchers that pinned that action at some
                 point in the past now route to MainActivity instead of
                 trying to resolve a missing activity (which would crash). -->
            <intent-filter>
                <action android:name="com.educms.player.LEGACY_PAIR" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <!-- USB sneakernet receiver (Sprint 7B) — fires when a stick is plugged
             into the Android device; UsbIngester scans for /edu-cms-content/. -->
        <receiver
            android:name=".usb.UsbAttachReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
            </intent-filter>
            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/usb_device_filter" />
        </receiver>

        <!-- Operator-facing USB ingest activity (PIN prompt + SAF folder picker) -->
        <activity
            android:name=".usb.UsbIngestActivity"
            android:exported="false"
            android:launchMode="singleTask"
            android:screenOrientation="fullSensor"
            android:theme="@style/Theme.EduCmsPlayer" />

        <!-- Foreground heartbeat service. Pings /screens/status every 30s
             so the dashboard sees ONLINE; foregroundServiceType=dataSync
             is the Android 14 contract for periodic network jobs. -->
        <service
            android:name=".heartbeat.HeartbeatService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Watchdog alarm receiver — fires every 15min to ensure
             HeartbeatService + the kiosk activity are alive even after
             OEM battery-saver kills. -->
        <receiver
            android:name=".watchdog.WatchdogReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.educms.player.WATCHDOG_TICK" />
            </intent-filter>
        </receiver>

        <!-- FileProvider for the OTA install intent. Android 7+ refuses
             to grant install permission to a file:// uri; everything must
             be served from a content://<authority>/<path> via FileProvider.
             The xml/file_paths.xml whitelist exposes only our private
             external-files /updates dir, never the rest of the device. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>
</manifest>
