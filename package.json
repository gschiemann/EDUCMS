{
  "name": "edu-cms-backend",
  "packageManager": "pnpm@9.0.0",
  "version": "1.0.0",
  "description": "Secure multi-tenant School CMS API",
  "scripts": {
    "start": "pnpm --filter api run start:prod",
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "postinstall": "pnpm run db:generate",
    "db:generate": "pnpm --filter @cms/database run db:generate",
    "db:push": "pnpm --filter @cms/database run db:push",
    "db:seed": "pnpm --filter @cms/database run db:seed",
    "db:setup": "pnpm run db:push && pnpm run db:seed",
    "dev:api": "pnpm --filter api run start:dev",
    "dev:web": "pnpm --filter web run dev",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "a11y:ci": "pnpm --filter web run a11y:ci",
    "lhci": "pnpm --filter web run lhci",
    "preflight": "pnpm install --frozen-lockfile --lockfile-only && pnpm --filter @cms/api-types build && pnpm --filter @cms/auth-core build && pnpm --filter @cms/ws-events build && pnpm --filter api build && pnpm --filter web build"
  },
  "dependencies": {
    "@cms/api-types": "workspace:*",
    "@cms/auth-core": "workspace:*",
    "@cms/ws-events": "workspace:*",
    "argon2": "^0.31.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.4",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^7.2.0",
    "@wdio/cli": "^9.27.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "turbo": "^2.9.6",
    "typescript": "^5.3.3"
  }
}
